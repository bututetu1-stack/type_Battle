{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "leaderboard": {
      "timeattack": {
        "$bucket": {
          ".read": "auth != null",
          ".indexOn": ["score"],
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['name', 'score', 'ts'])",
            "name": { ".validate": "newData.isString() && newData.val().length <= 16" },
            "score": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000" },
            "keys": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "kps": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "acc": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
            "words": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "maxCombo": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "theme": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "ts": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
